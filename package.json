    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "jsdom": "^27.0.0",
    "opentype.js": "^2.0.0",
    "prettier": "^3.6.2",
    "sass": "^1.99.0",
    "sharp": "^0.35.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.46.2",
