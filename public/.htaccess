<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  RewriteRule ^index\.html$ - [L]
  RewriteRule ^robots\.txt$ - [L]
  RewriteRule ^sitemap\.xml$ - [L]
  RewriteRule ^llms\.txt$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml font/woff2
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/plain "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "robots\.txt$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "sitemap\.xml$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "llms\.txt$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "\.(js|css|woff2|webp|png|jpg|jpeg|svg)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header always set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
